#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="${ROOT_DIR}/src:${PYTHONPATH:-}"
if [[ -f "${ROOT_DIR}/.env" && -z "${SUPER_BROWSER_SKIP_ENV_FILE:-}" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${ROOT_DIR}/.env"
  set +a
fi
exec python3 -m super_browser.cli "$@"

